{
  "manifest_version": 3,
  "name": "Quiz Automation Helper",
  "version": "1.0",
  "description": "Automates quiz answering by using Gemini API",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["*://lms2.ai.saveetha.in/*", "https://generativelanguage.googleapis.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://lms2.ai.saveetha.in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
